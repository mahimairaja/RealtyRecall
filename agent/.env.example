# LiveKit connection (server URL + API credentials for the agent worker).
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Model providers. OPENAI powers the LLM; DEEPGRAM powers STT + Aura TTS.
OPENAI_API_KEY=sk-your-openai-key
DEEPGRAM_API_KEY=your_deepgram_key
CARTESIA_API_KEY=sk_car_your_cartesia_key
GOOGLE_API_KEY=your_google_key

# Agent identity + limits.
AGENT_NAME=realty
AGENT_MAX_CALL_SECONDS=600

# Backend the agent calls for persona/listings/call logs.
BACKEND_URL=http://backend:8080
ENV=dev

# VoiceGateway telemetry (observe mode). When both are set, voicegateway.attach()
# pushes per-call STT/LLM/TTS cost + latency to the collector instead of a local
# SQLite file. The vk_ ingest key binds these rows to the RealtyRecall cloud
# tenant; each realtor is attributed separately via the per-call tenant_id.
VOICEGW_COLLECTOR_URL=https://cloud-api-production-dc6e.up.railway.app
VOICEGW_API_KEY=vk_your_ingest_key
